      "link": null,
      "locked": false,
      "updated": 1780048779469,
      "text": "col = blockDim.x * blockIdx.x + threadIdx.x\nrow = blockDim.y * blockIdx.y + threadIdx.y\n\nExample: Block(1,0), Thread(2,1)\n  col = 4*1 + 2 = 6\n  row = 4*0 + 1 = 1\n  offset = row * cols + col = 1*8 + 6 = 14",
      "fontSize": 12,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "col = blockDim.x * blockIdx.x + threadIdx.x\nrow = blockDim.y * blockIdx.y + threadIdx.y\n\nExample: Block(1,0), Thread(2,1)\n  col = 4*1 + 2 = 6\n  row = 4*0 + 1 = 1\n  offset = row * cols + col = 1*8 + 6 = 14",
      "lineHeight": 1.25,
      "index": "aQ",
      "autoResize": true
    },
