al Index Calculation", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "middle", "containerId": null, "originalText": "Global Index Calculation", "lineHeight": 1.25}, {"id": "formula_content", "type": "text", "x": 640, "y": 120, "width": 320, "height": 120, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 302, "version": 1, "versionNonce": 302, "isDeleted": false, "boundElements": [], "link": null, "locked": false, "updated": 1, "text": "col = blockDim.x * blockIdx.x + threadIdx.x\nrow = blockDim.y * blockIdx.y + threadIdx.y\n\nExample: Block(1,0), Thread(2,1)\n  col = 4*1 + 2 = 6\n  row = 4*0 + 1 = 1\n  offset = row * cols + col = 1*8 + 6 = 14", "fontSize": 12, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "col = blockDim.x * blockIdx.x + threadIdx.x\nrow = blockDim.y * blockIdx.y + threadIdx.y\n\nExample: Block(1,0), Thread(2,1)\n  col = 4*1 + 2 = 6\n  row = 4*0 + 1 = 1\n  offset = row * cols + col = 1*8 + 6 = 14", "lineHeight": 1.25}, {"id": "legend_box", "type": "rectangle", "x": 620, "y": 300, "width": 360, "height": 130, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "#f8f9fa", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": {"type": 3}, "seed": 400, "version": 1, "versionNonce": 400, "isDeleted": false, "boundElements": [], "link": null, "locked": false, "updated": 1}, {"id": "legend_text", "type": "text", "x": 640, "y": 310, "width": 320, "height": 110, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 401, "version": 1, "versionNonce": 401, "isDeleted": false, "boundElements": [], "link": null, "locked": false, "updated": 1, "text": "Legend:\n  Red border = Grid (2×2 blocks)\n  Blue area  = Block (4×4 threads each)\n  Green cell = Thread (x,y) within block\n\nTotal threads: 2×2 × 4×4 = 64\nCovers matrix up to 8×8", "fontSize": 12, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "Legend:\n  Red border = Grid (2×2 blocks)\n  Blue area  = Block (4×4 threads each)\n  Green cell = Thread (x,y) within block\n\nTotal threads: 2×2 × 4×4 = 64\nCovers matrix up to 8×8", "lineHeight": 1.25}, {"id": "col_axis", "type": "text", "x": 200, "y": 585, "width": 200, "height": 20, "angle": 0, "strokeColor": "#868e96", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 500, "version": 1, "versionNonce": 500, "isDeleted": false, "boundElements": [], "link": null, "locked": false, "updated": 1, "text": "← col (blockIdx.x) →", "fontSize": 12, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "containerId": null, "originalText": "← col (blockIdx.x) →", "lineHeight": 1.25}, {"id": "row_axis", "type": "text", "x": 20, "y": 300, "width": 20, "height": 120, "angle": 0, "strokeColor": "#868e96", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 501, "version": 1, "versionNonce": 501, "isDeleted": false, "boundElements": [], "link": null, "locked": false, "updated": 1, "text": "↑\nrow\n(blockIdx.y)\n↓", "fontSize": 11, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "containerId": null, "originalText": "↑\nrow\n(blockIdx.y)\n↓", "lineHeight": 1.25}], "appState": {"viewBackgroundColor": "#ffffff"}, "files": {}}